# Copy to ~/.config/git/config (or deploy via a private dotfiles module).
# Shared fragments live in ~/dotfiles; identity/employer fragments stay private.

[core]
	# Linux only; omit or set to true on Windows checkouts.
	autocrlf = input
	excludesFile = ~/.config/git/ignore

[pull]
	rebase = true

[include]
	path = ~/.config/git/common.inc
	path = ~/.config/git/gpg.inc
	path = ~/.config/git/user-personal.inc
#	path = ~/.config/git/forge.inc

# Optional private fragments (create locally or deploy from a private repo):
#	path = ~/.config/git/go-private-access-musiio.inc
#	path = ~/.config/git/darwin.inc

# [includeIf "gitdir:~/musiio/"]
#	path = ~/.config/git/user-musiio.inc